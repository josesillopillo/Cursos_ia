{
  "title": "AI Master - Dashboard",
  "panels": [
    {
      "title": "Backend Health",
      "type": "stat",
      "targets": [{ "expr": "probe_success{job=\"backend\"}" }]
    },
    {
      "title": "API Response Time",
      "type": "graph",
      "targets": [{ "expr": "avg(http_request_duration_seconds)" }]
    },
    {
      "title": "Active Users",
      "type": "stat",
      "targets": [{ "expr": "count(postgresql_rows_total)" }]
    }
  ]
}
