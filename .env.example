# ============================================
# AI Master - Variables de Entorno
# ============================================
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env al repositorio

# JWT Secret (cambiar en produccion por un valor seguro)
JWT_SECRET=dev-secret-change-in-production

# Database credentials
POSTGRES_USER=administrador
POSTGRES_PASSWORD=secure_password_123
POSTGRES_DB=ia_courses_db

# App
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081

# ============================================
# Infisical Secrets Management
# ============================================
# Para usar Infisical, descomenta y configura:
# INFISICAL_CLIENT_ID=tu_client_id
# INFISICAL_CLIENT_SECRET=tu_client_secret
# INFISICAL_SITE_URL=https://app.infisical.com
# INFISICAL_ENV=dev
# INFISICAL_PATH=/
